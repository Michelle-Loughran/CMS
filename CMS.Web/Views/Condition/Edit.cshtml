@model Condition
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="Condition" asp-action="Index">Conditions</a></li>
        <li class="breadcrumb-item active" aria-current="page">Edit</li>
    </ol>
</nav>
<div class="card rounded shadow p-4">

    <h3 class="mt-4 mb-4">Edit Condition</h3>
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- hide the id as its not user editable but needs to be in the -->
        <!-- form to ensure the Condition passed to the controller is complete -->
        <input type="hidden" asp-for="Id" />

        <!-- name -->
        <div class="row mt-3">
            <div class="col">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <!-- Description -->
            <div class="col">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
        </div>


<!-- submit button and cancel link which navigates to Index action -->
<div class="mt-3">
    <button type="submit" class="btn btn-primary" aria-label="save">Save</button>
    <a class="btn btn-secondary" asp-action="Details" asp-route-id="@Model.Id" aria-label="cancel">Cancel</a>
</div>
</form>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

