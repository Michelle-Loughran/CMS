@model IList<Patient>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Patients</li>
    </ol>
</nav>
      @* @if (User.IsInRole(Role.manager.ToString())) *@

    <div class="mt-4 mb-4">
       <!-- add an action link styled as a button to navigate to Create Action -->
       <a asp-action="Create" class="btn btn-primary btn-sm">Add Patient</a>
    </div>

<div class="card border rounded shadow p-4">
    <h3>Patient List</h3>
    <!-- Title bar -->
    <div class="d-flex align-items-center justify-content-between">
    <table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th> <th>Title</th> <th>Firstname</th> <th>Surname</th><th>DOB</th><th>National Insurance No</th> <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var p in Model) {
            <tr>
                <td>@p.Id</td> <td>@p.Title</td><td>@p.Firstname</td> <td>@p.Surname</td> <td>@p.DOB</td><td>@p.NationalInsuranceNo</td>
                <td>
                    <a asp-action="Details" asp-route-id="@p.Id">
                        <i class="material-icons" title="View Patient">View</i>
                    </a> 
                    @* @if (User.IsInRole("Admin") || User.IsInRole("Manager"))  *@
                    
                        <a asp-action="Edit" asp-route-id="@p.Id">
                            <i class="material-icons" title="Edit Patient">edit</i>
                        </a> 
                    
                    @* @if (User.IsInRole(Role.admin.ToString())) *@
                    
                        <a asp-action="Delete" asp-route-id=@p.Id>
                            <i class="material-icons" title="Delete Patient">delete</i>
                        </a>
                    
        
                </td>
            </tr>
        }
    </tbody>
</table>


