@model Patient

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="Patients" asp-action="Index">Patients</a></li>
        <li class="breadcrumb-item active" aria-current="page">Details</li>
    </ol>
</nav>
<div class="card rounded shadow p-4">
    <!-- Display patient  details -->
    <div class="row">
        <!-- Details and Navigation -->
        <div class="col-8 d-flex flex-column justify-content-between">
            <!-- Patient details -->
            <div>
                <h2 class="mb-4 text-primary">Patient Details</h2>
                <dl class="row">  
                    <dt class="col-4 pb-1">Title</dt>
                    <dd class="col-8 pb-1">@Model.Title</dd>
                    <dt class="col-4 pb-1">Firstname</dt>
                    <dd class="col-8 pb-1">@Model.Firstname</dd>
                    <dt class="col-4 pb-1">Surname</dt>
                    <dd class="col-8 pb-1">@Model.Surname</dd>
                    <dt class="col-4 pb-1">National Insurance No</dt>
                    <dd class="col-8 pb-1">@Model.NationalInsuranceNo</dd>
                    <dt class="col-4 pb-1">DOB</dt>
                    <dd class="col-8 pb-1">@Model.DOB</dd>
                    <dt class="col-4 pb-1">Street</dt>
                    <dd class="col-8 pb-1">@Model.Street</dd>
                     <dt class="col-4 pb-1">Town</dt>
                    <dd class="col-8 pb-1">@Model.Town</dd>
                    <dt class="col-4 pb-1">County</dt>
                    <dd class="col-8 pb-1">@Model.County</dd>
                    <dt class="col-4 pb-1">Country</dt>
                </dl>
            <div class="form-group">
          <label for="PhotoUrl">Photo</label>
          <input asp-for = "PhotoUrl" type = "url" class ="form-control"/>
          <span asp-validation-for="PhotoUrl" class = "text-danger"></span>
        </div> 
            </div>
            
        </div>

        <!-- Photo -->
        <div class="col-4">

            {
                <img src="@Model.PhotoUrl" class="img-fluid" alt="patient photo">
            } 
        </div>

            
    </div>    
</div>

