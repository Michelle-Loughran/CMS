@model Carer

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="Carer" asp-action="Index">Carers</a></li>
        <li class="breadcrumb-item active" aria-current="page">Add Carer Details</li>
    </ol>
</nav>
<div class="card rounded shadow p-4">
    <h3>Add Carer</h3>

    <form asp-action="Add">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mt-3">
                <label asp-for="Title" class="form-label"></label>
                <select id="title" name="title">
                <option value="Mr">Mr.</option>
                <option value="Mrs">Mrs.</option>
                <option value="Miss">Miss.</option>
                <option value="Ms">Ms.</option>
                <option value="Dr.">Dr.</option>
                </select>
            </div>

        <!-- name 2 columns in a row -->
        <div class="row mt-3">
            <div class="col">
                <label asp-for="Firstname" class="form-label"></label>
                <input asp-for="Firstname" class="form-control"/>
                <span  asp-validation-for="Firstname" class="text-danger"></span>
            </div>

            <div class="col">
                <label asp-for="Surname" class="form-label"></label>
                <input asp-for="Surname" class="form-control"/>
                <span  asp-validation-for="Surname" class="text-danger"></span>
            </div>
         </div>
         <!-- DOB & National Insurance No 2 columns in a row -->
        <!-- DOB -->
         <div class="row mt-3">
         <div class="col">
            <label asp-for="DOB" class="form-label"></label>
            <input asp-for="DOB" class="form-control"/>
            <span  asp-validation-for="DOB" class="text-danger"></span>
        </div>
        <!-- NationalInsuranceNo -->
        <div class="col">
            <label asp-for="NationalInsuranceNo" class="form-label"></label>
            <input asp-for="NationalInsuranceNo" class="form-control"/>
            <span  asp-validation-for="NationalInsuranceNo" class="text-danger"></span>
        </div>
                <!-- DBS Check - change to radio Y/N -->
        <div class="row mt-3">
        <div class="col">
            <label asp-for="NationalInsuranceNo" class="form-label"></label>
            <input asp-for="NationalInsuranceNo" class="form-control"/>
            <span  asp-validation-for="NationalInsuranceNo" class="text-danger"></span>
        </div>
        <!-- EmailAddress-->
        <div class="col">
            <label asp-for="EmailAddress" class="form-label"></label>
            <input asp-for="EmailAddress" class="form-control"/>
            <span  asp-validation-for="EmailAddress" class="text-danger"></span>
        </div>

        <!-- Street -->
        <div class="row mt-3">
        <div class="col">
            <label asp-for="Street" class="form-label"></label>
            <input asp-for="Street" class="form-control"/>
            <span  asp-validation-for="Street" class="text-danger"></span>
        </div>
        <!-- Town -->
        <div class="col">
            <label asp-for="Town" class="form-label"></label>
            <input asp-for="Town" class="form-control"/>
            <span  asp-validation-for="Town" class="text-danger"></span>
        </div>
        <!-- County -->
         <div class="row mt-3">
            <div class="col">
            <label asp-for="County" class="form-label"></label>
            <input asp-for="County" class="form-control"/>
            <span  asp-validation-for="County" class="text-danger"></span>
        </div>
         <!-- Postcode -->
            <div class="col">
            <label asp-for="Postcode" class="form-label"></label>
            <input asp-for="Postcode" class="form-control"/>
            <span  asp-validation-for="Postcode" class="text-danger"></span>
        </div>           
</div>

        <!-- MobileNumber -->
        <div class="row mt-3">
        <div class="col">
            <label asp-for="MobileNumber" class="form-label"></label>
            <input asp-for="MobileNumber" class="form-control"/>
            <span  asp-validation-for="MobileNumber" class="text-danger"></span>
        </div>

        <!-- HomeNumber -->
        <div class="col">
            <label asp-for="HomeNumber" class="form-label"></label>
            <input asp-for="HomeNumber" class="form-control"/>
            <span  asp-validation-for="HomeNumber" class="text-danger"></span>
        </div>

        <!-- Qualifications -->
        <div class="row mt-3"></div>
        <div class="col">
            <label asp-for="Qualifications" class="form-label"></label>
            <input asp-for="Qualifications" class="form-control"/>
            <span  asp-validation-for="Qualifications" class="text-danger"></span>
        </div>
            <div class="col">
            <label asp-for="Qualifications" class="form-label"></label>
            <input asp-for="Qualifications" class="form-control"/>
            <span  asp-validation-for="Qualifications" class="text-danger"></span>
        </div>
        <!--  Additional Qualifications -->
        <div class="row mt-3"></div>
        <div class="col">
            <label asp-for="Qualifications" class="form-label"></label>
            <input asp-for="Qualifications" class="form-control"/>
            <span  asp-validation-for="Qualifications" class="text-danger"></span>
        </div>
            <div class="col">
            <label asp-for="Qualifications" class="form-label"></label>
            <input asp-for="Qualifications" class="form-control"/>
            <span  asp-validation-for="Qualifications" class="text-danger"></span>
        </div>
        <!-------------------photurl-------------> 
        <!-- add PhotoUrl input group - ensure input field type is url -->
         <div class="row">
            <div class="form-group mt-3">
            <label asp-for="PhotoUrl" class="form-label"></label>
            <input asp-for="PhotoUrl" class="form-control"/>
            <span  asp-validation-for="PhotoUrl" class="text-danger"></span>
        </div>
    </div>
         <div class="col">
              <img src="@Model.PhotoUrl" class="img-fluid"> 
            </div>
    </div>



</div>
    <div class="mt-3">
            <button type="submit" class="btn btn-primary" aria-label="save">Save</button>
            <a class="btn btn-secondary" asp-action="Index" aria-label="cancel">Cancel</a>
        </div>

    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
