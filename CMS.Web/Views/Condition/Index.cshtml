@model IList<Condition>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Conditions</li>
    </ol>
</nav>
      @* @if (User.IsInRole(Role.manager.ToString())) *@

    <div class="mt-4 mb-4">
       <!-- add an action link styled as a button to navigate to Create Action -->
       <a asp-action="Create" class="btn btn-primary btn-sm">Add Condition</a>
    </div>

<div class="card border rounded shadow p-4">
    <h3>Carer List</h3>
    <!-- Title bar -->
    <div class="d-flex align-items-center justify-content-between">
    <table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th> <th>Name</th> <th>Description</th><th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var con in Model) {
            <tr>
                <td>@con.Id</td> <td>@con.Name</td><td>@con.Description</td> 
                <td>
                    <a asp-action="Details" asp-route-id="@con.Id">
                        <i class="material-icons" title="View">View</i>
                    </a> 
                    @* @if (User.IsInRole("Admin") || User.IsInRole("Manager"))  *@
                    
                        <a asp-action="Edit" asp-route-id="@con.Id">
                            <i class="material-icons" title="Edit">edit</i>
                        </a> 
                    
                    @* @if (User.IsInRole(Role.admin.ToString())) *@
                    
                        <a asp-action="Delete" asp-route-id=@con.Id>
                            <i class="material-icons" title="Delete Condition">delete</i>
                        </a>           
        
                </td>
            </tr>
        }
    </tbody>
</table>


