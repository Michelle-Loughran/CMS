@model IList<Patient>

<div class="card border rounded shadow p-4">

    <!-- Title bar -->
    <div class="d-flex align-items-center justify-content-between">
        <h3>Patient List</h3>
      @if (User.IsInRole(Role.manager.ToString()))
{
    <div class="mt-4 mb-4">
       <!-- add an action link styled as a button to navigate to Create Action -->
       <a asp-action="Create" class="btn btn-primary btn-sm">Create Patient</a>
    </div>
}

    <table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th> <th>Title</th> <th>Firstname</th> <th>Surname</th><th>DOB</th><th>National Insurance No</th> <th>Photo</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var patient in Model) {
            <tr>
                <td>@patient.Id</td> <td>@patient.Title</td><td>@patient.Firstname</td> <td>@patient.Surname</td> <td>@patient.DOB</td><td>@patient.NationalInsuranceNo</td><td>@patient.PhotoUrl</td>
                <td>
                    <a asp-action="Details" asp-route-id="@patient.Id">
                        <i class="material-icons" title="View Patient"></i>
                    </a> 
                    @if (User.IsInRole("Admin") || User.IsInRole("Manager")) 
                    {
                        <a asp-action="Edit" asp-route-id="@patient.Id">
                            <i class="material-icons" title="Edit Patient">edit</i>
                        </a> 
                    } 
                    @if (User.IsInRole(Role.admin.ToString()))
                    {
                        <a asp-action="Delete" asp-route-id=@patient.Id>
                            <i class="material-icons" title="Delete Patient">delete</i>
                        </a>
                    }
        
                </td>
            </tr>
        }
    </tbody>
</table>
  
        <a class="btn btn-sm btn-primary" asp-action="create" title="add patient" aria-label="add patient">
           <i class="bi bi-plus"></i> Create
        </a>
    </div>

