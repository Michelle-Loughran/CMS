@model Condition

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="Condition" asp-action="Index">Conditions</a></li>
        <li class="breadcrumb-item active" aria-current="page">Details</li>
    </ol>
</nav>

<h3 class="mt-4 mb-4">Condition Details:          @Model.Name </h3>        

<div class="row">
    <div class="col-8 card rounded shadow pt-3">
        <dl class="row">              
                <dt class=col-sm-5>Id</dt>
                <dd class="col-sm-7">@Model.Id</dd>
                <dt class=col-sm-5>Name</dt>
                <dd class="col-sm-7">@Model.Name</dd>
                <dt class="col-sm-5">Description</dt>
                <dd class="col-sm-7">@Model.Description</dd>
        </dl>
        </dl>
    </div>


<!-- action options -->
        <div class="mt-4 mb-4"> 
        <a asp-controller="Condition" asp-action="Index" class="btn btn-primary"><i class="bi bi-list"></i>
            Condition List
        </a>    
        <a asp-controller="Condition" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pen"></i>
            Edit Condition
        </a>  
        <a asp-controller="Condition" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-primary"><i class = "bi bi-trash"></i>
            Delete
        </a> 
      </div>


            
